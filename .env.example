# FastAPI API, Celery workers, scheduler, PostgreSQL/pgvector, and Redis.
ENVIRONMENT=production
ALLOW_DEMO_AUTH=false
JWT_ALGORITHM=HS256

# Must match BACKEND/backend and BACKEND/messaging-backend.
JWT_SECRET=replace-with-64-hex-character-shared-platform-secret

# Data stores.
POSTGRES_PASSWORD=replace-with-strong-database-password
DATABASE_URL=postgresql://techit:replace-me@postgres.example.com:5432/techit_db
REDIS_URL=rediss://redis.example.com:6379
CELERY_BROKER=rediss://redis.example.com:6379

# Browser/API boundaries.
ALLOWED_ORIGINS=https://app.example.com
MCP_BASE_URL=https://api.example.com/api/mcp
MCP_TIMEOUT=10

# Required provider integrations for production routing.
OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me

# Billing webhooks.
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional provider/storage/observability integrations.
COHERE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=techit-embeddings
ELEVENLABS_API_KEY=
AWS_S3_BUCKET=
SENTRY_DSN=
