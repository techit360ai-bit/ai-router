FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y gcc libpq-dev curl && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Worker default — overridden in docker-compose.yml per service (worker/scheduler/flower)
CMD ["celery", "-A", "workers.workers", "worker", "--loglevel=info", "-Q", "default,ai_heavy,ai_light,scheduled", "--concurrency=4"]